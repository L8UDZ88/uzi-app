// Uzi — data model. Postgres via Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  brands       Brand[]
  createdAt    DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignType String @default("physical") // "physical" | "digital"
  name      String   @default("")
  handle    String   @default("")
  tagline   String   @default("")
  region    String   @default("")
  voice     String   @default("")
  // The brand config seam — pillars, channels, inputs, cadence live here as JSON.
  pillars   Json     @default("{}")
  channels  Json     @default("{}")
  inputs    Json     @default("{}")
  cadence   String   @default("steady")
  onboarded Boolean  @default(false)
  schedule  ScheduleItem[]
  assets    Asset[]
  updatedAt DateTime @updatedAt
}

model ScheduleItem {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  date      DateTime
  pillar    String
  channel   String
  format    String   @default("")
  status    String   @default("queued")
  createdAt DateTime @default(now())
}

model Asset {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  source    String   @default("upload")
  url       String   @default("")
  createdAt DateTime @default(now())
}
