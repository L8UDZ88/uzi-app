// Uzi — data model. Postgres via Prisma.
generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  brand        Brand?
  createdAt    DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("")
  handle    String   @default("")
  tagline   String   @default("")
  region    String   @default("")
  voice     String   @default("")
  // The brand config seam — pillars, channels, inputs, cadence live here as JSON.
  // pillars: { "1": { on: bool, freq: string }, ... }
  // channels: { instagram: bool, linkedin: bool, ... }
  pillars   Json     @default("{}")
  channels  Json     @default("{}")
  inputs    Json     @default("{}") // { drive: bool, uploads: string[] }
  cadence   String   @default("steady")
  onboarded Boolean  @default(false)
  schedule  ScheduleItem[]
  assets    Asset[]
  updatedAt DateTime @updatedAt
}

model ScheduleItem {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  date      DateTime
  pillar    String
  channel   String
  status    String   @default("queued") // queued | generated | approved | published
  createdAt DateTime @default(now())
}

model Asset {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  source    String   @default("upload") // upload | drive
  url       String   @default("")
  createdAt DateTime @default(now())
}
