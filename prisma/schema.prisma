// Uzi — data model. Postgres via Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  // Google Drive connection (per user — one Google account powers all their campaigns)
  googleRefreshToken String?
  googleEmail        String?
  brands       Brand[]
  social       SocialConnection[]
  createdAt    DateTime @default(now())
}

// A linked social account the app can publish to (per user, per platform).
model SocialConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String   // linkedin | instagram | facebook | youtube | tiktok | x
  accessToken  String
  refreshToken String?
  externalId   String?  // platform identity (LinkedIn URN, FB page id, channel id…)
  displayName  String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  @@unique([userId, platform])
}

model Brand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignType String @default("physical") // "physical" | "digital"
  name      String   @default("")
  handle    String   @default("")
  tagline   String   @default("")
  region    String   @default("")
  voice     String   @default("")
  // The brand config seam — pillars, channels, inputs, cadence live here as JSON.
  pillars   Json     @default("{}")
  channels  Json     @default("{}")
  inputs    Json     @default("{}")
  cadence   String   @default("steady")
  omni      Boolean  @default(false) // Omni mode: every pillar fans to ALL channels, format auto-tailored per channel
  onboarded Boolean  @default(false)
  autoDeliver Boolean @default(false) // when true, approved posts auto-publish on schedule
  schedule  ScheduleItem[]
  assets    Asset[]
  products  ProductImage[]
  transcripts Transcript[]
  updatedAt DateTime @updatedAt
}

// Cached speech-to-text for a library asset (audio/video), so we transcribe each file once.
model Transcript {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  fileId    String   // Google Drive file id
  text      String   @db.Text
  words     Json     @default("[]") // [{ text, start, end }] word-level timings
  createdAt DateTime @default(now())
  @@unique([brandId, fileId])
}

model ScheduleItem {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  date      DateTime
  pillar    String
  channel   String
  format    String   @default("")
  city      String?  // for "Now in [city]" posts — the specific city this post anchors to
  beat      String?  // Story Arc: the Hero Frame beat id this post carries
  beatName  String?  // human-readable beat name
  phase     String?  // 4-S phase: Start | Struggle | Success | Service
  loop      Int?     // which loop of the arc (0-based) — drives escalation
  status    String   @default("queued") // queued | approved | ready | published | failed
  caption     String?  @db.Text          // snapshot of approved copy, for publishing
  mediaUrl    String?                     // generated/uploaded visual to publish
  publishedAt DateTime?
  externalUrl String?                     // link to the live post
  publishError String?
  createdAt DateTime @default(now())
}

// Uploaded transparent product images (per campaign), composited onto scenes.
model ProductImage {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String   @default("product")
  kind      String   @default("product") // product | logo (brand mark / design to infuse)
  data      String   @db.Text // base64 PNG
  createdAt DateTime @default(now())
}

// Short-lived generated media (e.g. voiceover mp3) served by URL so the render service can fetch it.
model RenderAsset {
  id        String   @id @default(cuid())
  mime      String   @default("audio/mpeg")
  data      String   @db.Text // base64
  createdAt DateTime @default(now())
}

model Asset {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  source    String   @default("upload")
  url       String   @default("")
  createdAt DateTime @default(now())
}
